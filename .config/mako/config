# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.

# Global Settings
font=Fira Code Regular 11
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay
anchor=top-right
background-color=#282828d8
width=600
height=100
margin=5
padding=0,5,10
border-size=2
border-color=#a89984
border-radius=15
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=1

# Settings for normal messages
[urgency=normal]
border-color=#a89984

# Settings for urgent messages
[urgency=high]
border-color=#bf616a
default-timeout=0

# Uncomment to add settings for specific apps
# [app-name=]
# border-color=
#
# [summary~="log-.*"]
# border-color=
